^.*\.Rproj$
^\.Rproj\.user$
^\.vscode$
^cran-comments\.md$
^LICENSE\.md$
^\.github$
^README\.Rmd$
^_pkgdown\.yml$
^docs$
^pkgdown$
^.lintr$
^\.covrignore$
^man/figures/cheatsheets\.pdf$
^data-raw$
^shiny$
^CRAN-SUBMISSION$
^vignettes/.*\.original$
^vignettes/comparison-packages-results\.RData$

# Developer / tooling files not needed in the CRAN tarball.
^AGENTS\.md$
^CLAUDE\.md$
^\.claude$
^prof\.out$
^CMakeLists\.txt$
^cmake$
^cpp$
^include$
^examples$
^ci$
^build$
^bazel-.*$

# Abseil build artefacts generated by configure (machine-specific paths).
^src/Makevars\.abseil$
^src/libabsl\.a$
^src/absl_objs$
^src/standalone$
^gen_package$

# Python build artefacts.
^fastcpd\.egg-info$
^.*\.egg-info$
^dist$
^__pycache__$
^\.pytest_cache$

# Python files.
^tests/.*\.py$
^python$
^\.clang-format$
^pyproject\.toml$
^pytest\.ini$
^requirements\.in$
^requirements_lock\.txt$
^pdoc$
